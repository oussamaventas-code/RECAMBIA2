# Copia este archivo a .env.local y rellena los valores reales.
# .env.local NUNCA se sube a git (ver .gitignore).

# Contraseña compartida para entrar en /presupuesto/nuevo (el creador
# interno de presupuestos). Solo la conoce el equipo de RECAMBIA.
ADMIN_PASSWORD=

# Cadena aleatoria para firmar los links de presupuesto (evita que se pueda
# manipular el precio editando la URL). Genera una con, por ejemplo:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
QUOTE_SIGNING_SECRET=

# Claves de Stripe (Dashboard → Developers → API keys).
# Usa las claves de test (sk_test_...) mientras probáis; cuando esté listo
# para cobrar de verdad, cambia a las claves live (sk_live_...).
STRIPE_SECRET_KEY=

# Firma del webhook (Dashboard → Developers → Webhooks → añade un endpoint
# apuntando a https://tu-dominio/api/stripe/webhook, evento
# checkout.session.completed). En local, usa `stripe listen` de la Stripe CLI.
STRIPE_WEBHOOK_SECRET=

# Supabase (base de datos del CRM de presupuestos y ventas).
# 1. Crea un proyecto en https://supabase.com
# 2. SQL Editor -> pega y ejecuta supabase/schema.sql
# 3. Copia estos dos valores desde Settings -> API:
#    - Project URL
#    - service_role key (secreta: SOLO en el servidor, nunca en el navegador)
# Si se dejan vacios, el CRM usa un archivo local (.data/crm.json) como respaldo.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Número de Bizum donde recibís los pagos de presupuestos (el que sale en la
# ficha del cliente junto al importe y el concepto). Formato libre, por
# ejemplo 612345678. Si se deja vacío, la ficha solo ofrece pagar con tarjeta.
BIZUM_PHONE=
